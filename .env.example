# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Firebase (only NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET is required for uploads;
# the rest are kept for parity with the Firebase web config snippet).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-bucket.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Vercel Analytics (Optional)
NEXT_PUBLIC_ANALYTICS_ID=

# Email forwarding for the Connect / Newsletter form (pick one)
# RESEND_API_KEY=
# RESEND_FROM=Hidden Gems <onboarding@resend.dev>
# WEB3FORMS_KEY=
